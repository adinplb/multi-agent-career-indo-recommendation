# =============================================================================
# Indo-Career AI — Environment Configuration
# Salin file ini: cp .env.example .env  lalu isi nilai yang sebenarnya
# JANGAN commit file .env ke git!
# =============================================================================

# -----------------------------------------------------------------------------
# ANTHROPIC API — Primary LLM provider
# Daftar di: https://platform.anthropic.com  (BERBEDA dari claude.ai/Claude Pro)
# Setelah daftar → Settings → API Keys → Create Key
# Billing terpisah dari Claude Pro subscription
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Per-agent model assignment:
#
#  Parallel agents (kecepatan & biaya diutamakan):
#    claude-haiku-4-5-20251001  → $1/$5 per MTok, tercepat
#
#  Sequential agents (kualitas diutamakan, output dilihat user):
#    claude-sonnet-4-6          → $3/$15 per MTok, reasoning & Bahasa Indonesia terbaik
#
# Estimasi biaya per analisis lengkap (~10K token total): ~$0.05 - $0.10
#
PROFILER_MODEL=claude-haiku-4-5-20251001    # Parallel: cepat & murah
ANALYST_MODEL=claude-haiku-4-5-20251001     # Parallel: cepat & murah
GAP_MODEL=claude-sonnet-4-6                 # Fan-In kritis: kualitas reasoning
STRATEGIST_MODEL=claude-sonnet-4-6          # Output utama: Bahasa Indonesia terbaik

# -----------------------------------------------------------------------------
# FALLBACK: OpenRouter — aktif jika ANTHROPIC_API_KEY kosong
# Menggunakan variabel standar OPENAI_* (kompatibel dengan langchain-openai)
# Daftar di: https://openrouter.ai
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=x-ai/grok-4-fast                  # Satu model untuk semua agent via OpenRouter

# -----------------------------------------------------------------------------
# Shared LLM Settings (berlaku untuk semua agent & provider)
# -----------------------------------------------------------------------------
AI_MAX_TOKENS=1200                          # Batas token output per panggilan
AI_TEMPERATURE=0.35                         # Suhu ekstraksi (Profiler, Analyst, Gap Analyzer)
AI_RECOMMENDATION_TEMPERATURE=0.3           # Suhu Strategist (roadmap lebih engaging)

# -----------------------------------------------------------------------------
# DuckDuckGo Search — 100% GRATIS, tidak perlu API key
# -----------------------------------------------------------------------------
# (tidak perlu konfigurasi apapun)

# -----------------------------------------------------------------------------
# Local dataset paths
# -----------------------------------------------------------------------------
DATASET_PATH=dataset/Filtered_Jobs_4000.csv
ONET_PATH=dataset/Occupation Data.csv
CLASSIFIED_JOBS_PATH=dataset/sbert_classified_jobs.csv

CHROMA_PERSIST_DIR=.chromadb
API_BASE_URL=http://localhost:8000
