# =============================================================================
# Indo-Career AI — Environment Configuration
# Salin file ini: cp .env.example .env  lalu isi nilai yang sebenarnya
# JANGAN commit file .env ke git!
# =============================================================================

# -----------------------------------------------------------------------------
# TAVILY SEARCH — Real-time job data (menggantikan DuckDuckGo)
# Daftar gratis di: https://tavily.com  (1.000 req/bulan gratis)
# Budget per analisis: ~4 credits (jobs + salary + trends + bootcamp)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-your-key-here

# -----------------------------------------------------------------------------
# ANTHROPIC API — Primary LLM provider
# Daftar di: https://platform.anthropic.com
# Billing terpisah dari Claude Pro subscription
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Per-agent model assignment:
#  Parallel agents (kecepatan & biaya):  claude-haiku-4-5-20251001  → $1/$5 per MTok
#  Sequential agents (kualitas):         claude-sonnet-4-6          → $3/$15 per MTok
PROFILER_MODEL=claude-haiku-4-5-20251001
GAP_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# FALLBACK: OpenRouter — aktif jika ANTHROPIC_API_KEY kosong
# Embedding text-embedding-3-small juga menggunakan key ini (via OpenRouter)
# Daftar di: https://openrouter.ai
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=x-ai/grok-4-fast

# Embedding model untuk FAISS semantic search
# Menggunakan OPENAI_API_KEY + OPENAI_BASE_URL di atas (via OpenRouter)
# text-embedding-3-small = $0.02/MTok — sangat murah
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Shared LLM Settings
# -----------------------------------------------------------------------------
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.35
AI_RECOMMENDATION_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
API_BASE_URL=http://localhost:8000
