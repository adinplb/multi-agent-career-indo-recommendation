# =============================================================================
# Indo-Career AI — Environment Configuration
# Salin file ini: cp .env.example .env  lalu isi nilai yang sebenarnya
# JANGAN commit file .env ke git!
# =============================================================================

# -----------------------------------------------------------------------------
# TAVILY SEARCH — Real-time job data
# Daftar gratis di: https://tavily.com  (1.000 req/bulan gratis)
# Budget per analisis: ~4 credits (jobs + salary + trends + bootcamp)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-your-key-here

# -----------------------------------------------------------------------------
# OPENROUTER — Primary LLM provider untuk semua agent
# Daftar di: https://openrouter.ai
# Satu API key untuk semua model: Claude, Grok, GPT-4o, Gemini, dll.
# Juga digunakan untuk FAISS embeddings (text-embedding-3-small)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# Model per agent — semua via OpenRouter
# Lihat daftar model di: https://openrouter.ai/models
#
# Rekomendasi kombinasi:
#   Paralel (kecepatan & biaya): x-ai/grok-4-fast, google/gemini-flash-1.5
#   Sequential (kualitas):       anthropic/claude-sonnet-4-6, openai/gpt-4o
#   Best quality:                anthropic/claude-opus-4, openai/o3
# -----------------------------------------------------------------------------

# Profiler Agent — berjalan PARALEL dengan Analyst (ekstraksi CV)
PROFILER_MODEL=x-ai/grok-4-fast

# Market Analyst Agent — berjalan PARALEL dengan Profiler (riset pasar)
ANALYST_MODEL=x-ai/grok-4-fast

# Gap Analyzer Agent — sequential Fan-In (reasoning skill gap)
GAP_MODEL=anthropic/claude-sonnet-4-6

# Strategist Agent — sequential (roadmap 6 bulan Bahasa Indonesia)
STRATEGIST_MODEL=anthropic/claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Shared LLM Settings
# -----------------------------------------------------------------------------
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.35
AI_RECOMMENDATION_TEMPERATURE=0.3

# Embedding model untuk FAISS semantic search
# Menggunakan OPENAI_API_KEY + OPENAI_BASE_URL di atas (via OpenRouter)
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
API_BASE_URL=http://localhost:8000
